# Copie para .env e preencha com os valores do seu projeto Supabase
# (Project Settings -> API). A anon key é publicável (pode ir no app).
EXPO_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=COLE_AQUI_A_ANON_PUBLIC_KEY

# URL WebSocket do Hermes (FastAPI local exposto via Cloudflare Tunnel).
# Use wss:// e termine em /ws. Ex.: wss://algo.trycloudflare.com/ws
EXPO_PUBLIC_HERMES_WS_URL=wss://SEU-TUNNEL.trycloudflare.com/ws
