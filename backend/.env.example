# Copie para backend/.env e preencha.
# Supabase (Project Settings -> API)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=eyJ...           # anon/public (usada só para validar o token do usuário)
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # SECRETA — só no seu PC, nunca no app

# Onde está o cérebro do Hermes:
#   hermes_cli (default) | hermes_api | http | command | python | openrouter
#
# ⚡ VELOCIDADE: "hermes_cli" abre um processo NOVO do Hermes a cada mensagem
#    (recarrega skills/plugins do zero toda vez = lento). É a causa da demora.
#    O Telegram NÃO faz isso — usa o Hermes JÁ LIGADO (gateway quente).
#    Para ficar rápido igual ao Telegram, rode o gateway e troque para:
#        HERMES_BACKEND=hermes_api
#        HERMES_API_URL=http://localhost:8080   (porta do seu gateway)
#    (ex.: `hermes gateway run --platform api-server`). Mesmo cérebro, sem o
#    "cold start" a cada mensagem.
HERMES_BACKEND=hermes_cli

# (hermes_cli) Hermes Agent em one-shot: `hermes -z "<msg>"` — funciona em qualquer
# instalação do Hermes via CLI. CONTINUE=1 mantém memória por usuário entre mensagens.
HERMES_CLI_BIN=hermes
HERMES_CLI_CONTINUE=1
HERMES_CLI_SESSION_PREFIX=continental
HERMES_CLI_TIMEOUT=180

# (hermes_api) gateway HTTP do Hermes que exponha POST /chat
HERMES_API_URL=http://localhost:8080

# (openrouter) fallback — gateway de modelos de IA
OPENROUTER_API_KEY=

# (http) seu Hermes expõe um endpoint que recebe JSON {text,history,settings,project,user_id}
#   e devolve {text, buttons?, narrate?}
HERMES_HTTP_URL=
HERMES_HTTP_AUTH=

# (command) seu Hermes é um script/CLI; recebe JSON no stdin e devolve JSON/texto no stdout
HERMES_COMMAND=

# (python) seu Hermes é um módulo importável: "pacote.modulo:funcao" (recebe o payload dict)
HERMES_PYTHON_TARGET=

# Servidor
HOST=0.0.0.0
PORT=8000
